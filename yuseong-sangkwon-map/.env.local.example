# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kakao
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-javascript-key
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# 공공데이터포털 (소상공인시장진흥공단 상권분석 API 인증키)
PUBLIC_DATA_API_KEY=your-public-data-api-key

# /api/public-data/sync 호출 시 Authorization: Bearer {SYNC_SECRET_KEY} 로 검증하는 임의 비밀키
SYNC_SECRET_KEY=your-sync-secret-key
